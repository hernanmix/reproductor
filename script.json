</div>
</header>
<main class="pt-24 md:pt-36 lg:pt-48 pb-16 px-4 md:px-12 lg:px-24 w-full max-w-[1920px] mx-auto min-h-screen flex flex-col items-center">
<section class="grid grid-cols-1 md:grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-12 lg:gap-16 w-full" id="events-container">
<!-- Skeleton Loaders -->
<div class="flex flex-col gap-6 w-full items-center">
<div class="w-full aspect-[16/9] rounded-2xl skeleton"></div>
<div class="w-[90%] h-16 rounded-full skeleton"></div>
</div>
<div class="flex flex-col gap-6 w-full items-center">
<div class="w-full aspect-[16/9] rounded-2xl skeleton"></div>
<div class="w-[90%] h-16 rounded-full skeleton"></div>
</div>
<div class="flex flex-col gap-6 w-full items-center">
<div class="w-full aspect-[16/9] rounded-2xl skeleton"></div>
<div class="w-[90%] h-16 rounded-full skeleton"></div>
</div>
</section>
</main>
<footer class="w-full flex flex-col justify-center items-center py-16 px-6 font-label text-sm md:text-base lg:text-lg font-light tracking-widest text-slate-400 bg-surface text-center">
<p class="font-bold opacity-60">HSPORTSEC COPYRIGHT © 2026</p>
</footer>
<script>
    // URL de ejemplo para el fetch. Reemplazar con la URL real de GitHub Raw.
    const API_URL = 'https://raw.githubusercontent.com/example/repo/main/events.json';

    // Datos de ejemplo en caso de que el fetch falle o para demostración
    const mockData = [
        {
            "id": 1,
            "title": "Emelec vs Católica",
            "image": "https://lh3.googleusercontent.com/aida-public/AB6AXuCj0HZitmiwdbPZ8qJfPykAIskaeACZzoFz-WckaQCUWFDFT_kql6y4o4JXfiA9XK9D-pNiz-_rqaxvDyynjk7wlrQUwiTK6IeLi7y5Fpentg3lCsdBHTtY1vMh750WTmT5byKxjCwzpSJu4-aaIpXRdD9haToXXRWy2cI7uNC9CnWuDeCQAsHjWFHWp0uBy0KCtU7Mw6FF7h0u5mWmkmKQVuN2CctFhyAxifXWBznKWOp31tDuo3qkPCc_OFa_77c-iEvkNF0FclFo",
            "startTime": "2024-05-20T19:00:00",
            "url": "https://t.me/hsportsec"
        },
        {
            "id": 2,
            "title": "Barcelona vs LDU",
            "image": "https://lh3.googleusercontent.com/aida-public/AB6AXuC1KkIPCihILKZz8GKWco3pLHWcAzgXOjM_pIp6jJwZXIVZ9cKsjvJjwz_JzA--dUTYNNRUwwqUoEzqaL14l8YjsEpaQYovLDz0qEooJswUwiI0i5V2qDaUyoJQ13Ig_eSq7E7P9MZ1qj9cYACDEDf3sFlZSJxi1QTwPzRVrJQoToFtTk3epYNpGbP7ZZKjHQLe2CBwXoYHWDDwr-GtQx6i_tikN7zobWI0JpX9PX--VfqcWQuxO61a7BrRRyNV2WmsrYe67ShgTDEf",
            "startTime": "2024-05-20T21:00:00",
            "url": "https://t.me/hsportsec"
        },
        {
            "id": 3,
            "title": "Real Madrid vs AC Milan",
            "image": "https://lh3.googleusercontent.com/aida-public/AB6AXuDagxrmOBlqCyY5jpyLybcpRP8H5By7OQUvOJ3VFBzh06EGvfT-96YGiEq0wznl7apf1QplAG0KfdE1AqZ8cXcmglG8__Z4hWyTHqdJGp90qEPgnS_nBO37ngE47qvSf7tcOU6ZUP1_r_tw2iicgAPajCNXaQPq0JOiBcoD5FLmr3dWMMIx6BEcM57G-CGGOPjbd3xcbinTcW0yB4PdoLrPIKNI7jgYoQgyZY4_7VnFfxSkcxBEScsc9biOA3PNrGU0T-VrV1ASoT3-",
            "startTime": "2024-05-20T23:30:00",
            "url": "https://t.me/hsportsec"
        }
    ];

    async function fetchEvents() {
        try {
            // Intento de fetch real
            // const response = await fetch(API_URL);
            // const events = await response.json();
            
            // Usamos mockData para esta demostración dinámica
            renderEvents(mockData);
        } catch (error) {
            console.error('Error fetching events:', error);
            // Fallback en caso de error
            renderEvents(mockData);
        }
    }

    function getStatusInfo(startTimeStr) {
        const now = new Date();
        const start = new Date(startTimeStr);
        const end = new Date(start.getTime() + (2 * 60 * 60 * 1000)); // +2 horas

        if (now >= end) {
            return { label: 'FINALIZADO', classes: 'text-slate-400 opacity-80', pulse: false };
        } else if (now >= start) {
            return { label: 'EN VIVO', classes: 'text-primary pulse-animation', pulse: true };
        } else {
            const timeString = start.toLocaleTimeString('es-ES', { 
                hour: '2-digit', 
                minute: '2-digit',
                hour12: true 
            }).toUpperCase();
            return { label: timeString, classes: 'text-white/90 font-light', pulse: false };
        }
    }

    function renderEvents(events) {
        const container = document.getElementById('events-container');
        container.innerHTML = '';

        events.forEach(event => {
            const status = getStatusInfo(event.startTime);
            
            const eventHtml = `
                <div class="flex flex-col gap-6 w-full items-center match-card">
                    <div class="relative w-full aspect-[16/9] md:aspect-[21/9] lg:aspect-[16/9] rounded-2xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.6)] group">
                        <img alt="${event.title}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" src="${event.image}"/>
                        <div class="absolute inset-0 card-overlay"></div>
                        <div class="absolute top-6 right-8 z-10">
                            <span class="text-white font-headline font-black text-xs md:text-sm lg:text-base tracking-[0.3em]">HSPORTSEC</span>
                        </div>
                        <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6 gap-2 md:gap-4">
                            <span class="status-label font-headline font-black text-2xl md:text-4xl lg:text-5xl tracking-tighter ${status.classes}">
                                ${status.label}
                            </span>
                            <h2 class="text-white font-headline font-bold text-2xl md:text-4xl lg:text-5xl tracking-tight drop-shadow-2xl max-w-[90%] leading-tight">
                                ${event.title}
                            </h2>
                        </div>
                    </div>
                    <a class="w-[90%] md:w-[85%] bg-[#26A5E4] text-white py-4 md:py-6 rounded-full font-black text-lg md:text-xl lg:text-2xl tracking-widest hover:brightness-110 active:scale-[0.97] transition-all shadow-2xl shadow-[#26A5E4]/40 flex items-center justify-center uppercase" href="${event.url}" target="_blank">
                        QUIERO VER
                    </a>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', eventHtml);
        });
    }

    // Inicialización y refresco cada minuto
    fetchEvents();
    setInterval(fetchEvents, 60000);
</script>
</body></html>
